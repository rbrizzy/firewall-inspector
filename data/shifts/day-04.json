{
  "id": "day-04",
  "index": 4,
  "briefing": {
    "title": "Day 4 — Spoofed sources",
    "body": "Attackers forge the source address to look like a trusted host. The deep inspector (press I) now shows an 'expected source' cross-check: when the claimed source address does not match where the packet actually came from, it is a spoofed-source attack and must be denied. Open the inspector on suspicious packets — the mismatch is flagged for you.",
    "examples": [
      { "verdict": "DENY", "why": "The deep inspector shows the claimed source does not match the real origin — spoofed." }
    ],
    "introducesConcepts": ["technique-rule", "spoofed-source"]
  },
  "ruleset": {
    "defaultVerdict": "ALLOW",
    "geoMap": { "185.220.100.0/24": "XX" },
    "rules": [
      { "id": "r-block-telnet", "description": "Deny inbound Telnet (TCP/23).", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 23 }, "verdict": "DENY", "isException": false,
        "source": { "kind": "RFC", "ref": "RFC 854 (Telnet)", "shownToPlayer": true } },
      { "id": "r-block-smb", "description": "Deny inbound SMB (TCP/445).", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 445 }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-block-rdp", "description": "Deny inbound RDP (TCP/3389) per CVE advisory.", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 3389 }, "verdict": "DENY", "isException": false,
        "source": { "kind": "CVE", "ref": "CVE-2019-0708 (BlueKeep, illustrative)", "shownToPlayer": true } },
      { "id": "r-block-spoof", "description": "Deny spoofed-source packets (claimed origin does not match real origin).", "priority": 120,
        "match": { "technique": "spoofed-source" }, "verdict": "DENY", "isException": false,
        "source": { "kind": "TECHNIQUE", "ref": "MITRE ATT&CK T1036 (Masquerading)", "shownToPlayer": true } },
      { "id": "r-block-badnet", "description": "Deny all traffic from the known-bad subnet 203.0.113.0/24.", "priority": 90,
        "match": { "srcCidr": "203.0.113.0/24" }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-block-db", "description": "Deny the database port (TCP/3306) from the internet.", "priority": 80,
        "match": { "protocol": "TCP", "dstPort": 3306 }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-geo-block", "description": "Deny sources in the geo-blocked region XX.", "priority": 70,
        "match": { "geo": "XX" }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-finance-db-allow", "description": "Exception: allow TCP/3306 from the finance VPN (10.20.0.0/16).", "priority": 180,
        "match": { "srcCidr": "10.20.0.0/16", "dstPort": 3306 }, "verdict": "ALLOW", "isException": true, "source": null }
    ]
  },
