{
  "id": "day-02",
  "index": 2,
  "briefing": {
    "title": "Day 2 — Known-bad subnets and exceptions",
    "body": "Two new ideas today. First, a whole source subnet (203.0.113.0/24) has been flagged as known-bad — deny anything from it. Second, exceptions: we deny the database port (TCP/3306) from the internet, EXCEPT from the finance VPN (10.20.0.0/16), which is allowed. Exceptions have higher priority, so a finance-VPN database packet is ALLOWED even though the general rule denies TCP/3306.",
    "examples": [
      { "verdict": "DENY", "why": "Source is in the known-bad subnet 203.0.113.0/24." },
      { "verdict": "ALLOW", "why": "TCP/3306 from the finance VPN (10.20.0.0/16) — the exception wins." },
      { "verdict": "DENY", "why": "TCP/3306 from the public internet — no exception applies." }
    ],
    "introducesConcepts": ["srcCidr-rule", "exception"]
  },
  "ruleset": {
    "defaultVerdict": "ALLOW",
    "geoMap": {},
    "rules": [
      { "id": "r-block-telnet", "description": "Deny inbound Telnet (TCP/23).", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 23 }, "verdict": "DENY", "isException": false,
        "source": { "kind": "RFC", "ref": "RFC 854 (Telnet)", "shownToPlayer": true } },
      { "id": "r-block-smb", "description": "Deny inbound SMB (TCP/445).", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 445 }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-block-badnet", "description": "Deny all traffic from the known-bad subnet 203.0.113.0/24.", "priority": 90,
        "match": { "srcCidr": "203.0.113.0/24" }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-block-db", "description": "Deny the database port (TCP/3306) from the internet.", "priority": 80,
        "match": { "protocol": "TCP", "dstPort": 3306 }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-finance-db-allow", "description": "Exception: allow TCP/3306 from the finance VPN (10.20.0.0/16).", "priority": 180,
        "match": { "srcCidr": "10.20.0.0/16", "dstPort": 3306 }, "verdict": "ALLOW", "isException": true, "source": null }
    ]
  },
  "clockSeconds": null,
  "passThreshold": { "minAccuracy": 0.75, "maxSecurityIncidents": 2, "minMorale": 50 },
