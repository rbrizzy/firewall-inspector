{
  "id": "day-01",
  "index": 1,
  "briefing": {
    "title": "Day 1 — Blocking legacy ports",
    "body": "Welcome to the inspection desk. Today you enforce two simple rules: deny inbound Telnet (TCP port 23) and inbound SMB (TCP port 445) from the outside — both are risky legacy services. Everything else is allowed by default. Read each packet's protocol and destination port, then stamp ALLOW or DENY.",
    "examples": [
      { "verdict": "DENY", "why": "TCP to destination port 23 is Telnet — denied." },
      { "verdict": "ALLOW", "why": "TCP to port 443 (HTTPS) matches no deny rule — allowed by default." }
    ],
    "introducesConcepts": ["protocol-rule", "dstPort-rule"]
  },
  "ruleset": {
    "defaultVerdict": "ALLOW",
    "rules": [
      {
        "id": "r-block-telnet",
        "description": "Deny inbound Telnet (TCP/23) — cleartext legacy protocol.",
        "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 23 },
        "verdict": "DENY",
        "isException": false,
        "source": { "kind": "RFC", "ref": "RFC 854 (Telnet)", "shownToPlayer": true }
      },
      {
        "id": "r-block-smb",
        "description": "Deny inbound SMB (TCP/445) from the internet.",
        "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 445 },
        "verdict": "DENY",
        "isException": false,
        "source": null
      }
    ]
  },
  "clockSeconds": null,
  "passThreshold": { "minAccuracy": 0.7, "maxSecurityIncidents": 2, "minMorale": 50 },
