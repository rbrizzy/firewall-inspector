{
  "id": "day-08",
  "index": 8,
  "briefing": {
    "title": "Day 8 — Reflection attacks and the full desk",
    "body": "Final shift. One last rule: UDP traffic arriving from a privileged source port (0–1023) is the signature of a reflection/amplification attack (for example spoofed NTP or DNS responses) — deny it. Ordinary UDP (like a DNS query from a high source port) is fine. Every rule you have learned is in force today; use the rulebook and the deep inspector freely.",
    "examples": [
      { "verdict": "DENY", "why": "UDP from source port 123 (privileged) — reflection/amplification pattern." },
      { "verdict": "ALLOW", "why": "UDP DNS query from a high, ephemeral source port." }
    ],
    "introducesConcepts": ["srcPort-rule"]
  },
  "ruleset": {
    "defaultVerdict": "ALLOW",
    "geoMap": { "185.220.100.0/24": "XX" },
    "rules": [
      { "id": "r-block-telnet", "description": "Deny inbound Telnet (TCP/23).", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 23 }, "verdict": "DENY", "isException": false,
        "source": { "kind": "RFC", "ref": "RFC 854 (Telnet)", "shownToPlayer": true } },
      { "id": "r-block-smb", "description": "Deny inbound SMB (TCP/445).", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 445 }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-block-rdp", "description": "Deny inbound RDP (TCP/3389) per CVE advisory.", "priority": 100,
        "match": { "protocol": "TCP", "dstPort": 3389 }, "verdict": "DENY", "isException": false,
        "source": { "kind": "CVE", "ref": "CVE-2019-0708 (BlueKeep, illustrative)", "shownToPlayer": true } },
      { "id": "r-block-reflection", "description": "Deny UDP from a privileged source port (0-1023) — reflection/amplification.", "priority": 60,
        "match": { "protocol": "UDP", "srcPort": { "min": 0, "max": 1023 } }, "verdict": "DENY", "isException": false,
        "source": { "kind": "TECHNIQUE", "ref": "MITRE ATT&CK T1498 (Network DoS)", "shownToPlayer": true } },
      { "id": "r-block-xmas", "description": "Deny Xmas-scan probes (TCP flags FIN+URG+PSH).", "priority": 95,
        "match": { "protocol": "TCP", "flags": ["FIN", "URG", "PSH"] }, "verdict": "DENY", "isException": false,
        "source": { "kind": "RFC", "ref": "RFC 793 (TCP flags)", "shownToPlayer": true } },
      { "id": "r-block-spoof", "description": "Deny spoofed-source packets.", "priority": 120,
        "match": { "technique": "spoofed-source" }, "verdict": "DENY", "isException": false,
        "source": { "kind": "TECHNIQUE", "ref": "MITRE ATT&CK T1036 (Masquerading)", "shownToPlayer": true } },
      { "id": "r-block-frag", "description": "Deny fragmented malicious payloads.", "priority": 120,
        "match": { "technique": "fragmented-payload" }, "verdict": "DENY", "isException": false,
        "source": { "kind": "TECHNIQUE", "ref": "MITRE ATT&CK T1027 (Obfuscated/Fragmented)", "shownToPlayer": true } },
      { "id": "r-block-c2", "description": "Deny disguised command-and-control (C2) traffic.", "priority": 120,
        "match": { "technique": "disguised-c2" }, "verdict": "DENY", "isException": false,
        "source": { "kind": "TECHNIQUE", "ref": "MITRE ATT&CK T1071 (Application Layer Protocol / C2)", "shownToPlayer": true } },
      { "id": "r-block-sig", "description": "Deny payloads matching advisory signature SIG-C2-BEACON.", "priority": 110,
        "match": { "signatureId": "SIG-C2-BEACON" }, "verdict": "DENY", "isException": false,
        "source": { "kind": "TECHNIQUE", "ref": "MITRE ATT&CK T1071 (Application Layer Protocol / C2)", "shownToPlayer": true } },
      { "id": "r-block-badnet", "description": "Deny all traffic from the known-bad subnet 203.0.113.0/24.", "priority": 90,
        "match": { "srcCidr": "203.0.113.0/24" }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-block-db", "description": "Deny the database port (TCP/3306) from the internet.", "priority": 80,
        "match": { "protocol": "TCP", "dstPort": 3306 }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-geo-block", "description": "Deny sources in the geo-blocked region XX.", "priority": 70,
        "match": { "geo": "XX" }, "verdict": "DENY", "isException": false, "source": null },
      { "id": "r-finance-db-allow", "description": "Exception: allow TCP/3306 from the finance VPN (10.20.0.0/16).", "priority": 180,
        "match": { "srcCidr": "10.20.0.0/16", "dstPort": 3306 }, "verdict": "ALLOW", "isException": true, "source": null }
    ]
  },
  "clockSeconds": 150,
